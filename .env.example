# ================================================
# SHLINK - KONFIGURIMI I MJEDISIT
# Kopjo kete file si: cp .env.example .env
# dhe ndrysho vlerat sipas nevojave tua
# ================================================

# --- DATABASE ---
DB_NAME=shlink
DB_USER=shlink
DB_PASSWORD=shlink_secret_pass_2024

# --- DOMAIN ---
# Ndrysho me domain-in tend real p.sh: myshort.link
DEFAULT_DOMAIN=localhost
IS_HTTPS_ENABLED=false

# --- API KEY ---
# Kjo eshte celes-i per te aksesuar API-n
# Ndrysho me nje password te forte!
INITIAL_API_KEY=my-super-secret-api-key-change-me

# --- GEOLITE (opsionale - per statistika gjeografike) ---
# Regjistrohu ne: https://www.maxmind.com/en/geolite2/signup
GEOLITE_LICENSE_KEY=

# --- PORTS ---
WEB_PORT=3000
NGINX_PORT=80
DB_PORT=5432
